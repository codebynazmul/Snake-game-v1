<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Snake Game v2.0 - Professional Edition</title>
    <style>
        :root {
            --bg-color: #0f172a;
            --canvas-bg: #020617;
            --primary-color: #38bdf8;
            --secondary-color: #22c55e;
            --danger-color: #ef4444;
            --text-color: #f8fafc;
            --panel-bg: rgba(30, 41, 59, 0.7);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            overflow: hidden;
        }

        .container {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 20px;
            padding: 20px;
            max-width: 600px;
            width: 100%;
        }

        header {
            text-align: center;
        }

        h1 {
            font-size: 2.5rem;
            margin-bottom: 5px;
            background: linear-gradient(to right, var(--primary-color), var(--secondary-color));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 10px 20px rgba(0,0,0,0.3);
        }

        .stats-container {
            display: flex;
            justify-content: space-between;
            width: 100%;
            background: var(--panel-bg);
            padding: 15px 25px;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.1);
            backdrop-filter: blur(10px);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        }

        .stat-item {
            text-align: center;
        }

        .stat-label {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #94a3b8;
            margin-bottom: 5px;
        }

        .stat-value {
            font-size: 1.5rem;
            font-weight: bold;
            color: var(--primary-color);
        }

        .game-area {
            position: relative;
            line-height: 0;
        }

        canvas {
            background: var(--canvas-bg);
            border: 4px solid var(--primary-color);
            border-radius: 12px;
            box-shadow: 0 0 30px rgba(56, 189, 248, 0.3);
            max-width: 100%;
            height: auto;
        }

        .overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background: rgba(15, 23, 42, 0.85);
            border-radius: 8px;
            z-index: 10;
            transition: opacity 0.3s ease;
        }

        .hidden {
            display: none !important;
            opacity: 0;
        }

        .btn {
            background: var(--primary-color);
            color: var(--bg-color);
            border: none;
            padding: 12px 28px;
            font-size: 1.1rem;
            font-weight: bold;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 15px;
        }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(56, 189, 248, 0.4);
            filter: brightness(1.1);
        }

        .btn:active {
            transform: translateY(0);
        }

        .controls-hint {
            margin-top: 10px;
            font-size: 0.9rem;
            color: #64748b;
            display: flex;
            gap: 20px;
        }

        .key {
            background: #334155;
            padding: 2px 8px;
            border-radius: 4px;
            color: #e2e8f0;
            font-size: 0.8rem;
            border-bottom: 2px solid #1e293b;
        }

        footer {
            margin-top: 20px;
            padding: 10px;
            text-align: center;
        }

        footer a {
            color: var(--primary-color);
            text-decoration: none;
            font-weight: 600;
            transition: color 0.2s;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        footer a:hover {
            color: var(--secondary-color);
        }

        .linkedin-icon {
            width: 20px;
            height: 20px;
            fill: currentColor;
        }

        /* Particles for food effect */
        .particle {
            position: absolute;
            pointer-events: none;
            border-radius: 50%;
        }

        @keyframes particle-fade {
            0% { transform: scale(1); opacity: 1; }
            100% { transform: scale(0); opacity: 0; }
        }

        /* Mobile Controls */
        .mobile-controls {
            display: none;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            margin-top: 15px;
        }

        .m-btn {
            width: 60px;
            height: 60px;
            background: var(--panel-bg);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: var(--text-color);
            cursor: pointer;
            user-select: none;
        }

        @media (max-width: 600px) {
            .mobile-controls {
                display: grid;
            }
            h1 { font-size: 1.8rem; }
            .container { padding: 10px; }
        }
    </style>
</head>
<body>

<div class="container">
    <header>
        <h1>SNAKE V2.0</h1>
    </header>

    <div class="stats-container">
        <div class="stat-item">
            <div class="stat-label">Score</div>
            <div id="score" class="stat-value">0</div>
        </div>
        <div class="stat-item">
            <div class="stat-label">High Score</div>
            <div id="highScore" class="stat-value">0</div>
        </div>
        <div class="stat-item">
            <div class="stat-label">Level</div>
            <div id="level" class="stat-value">1</div>
        </div>
    </div>

    <div class="game-area" id="gameArea">
        <canvas id="game" width="400" height="400"></canvas>
        
        <div id="startOverlay" class="overlay">
            <h2 style="margin-bottom: 10px;">Ready?</h2>
            <p style="color: #94a3b8; margin-bottom: 20px;">Collect red dots, grow longer, don't hit walls!</p>
            <button class="btn" onclick="startGame()">Start Game</button>
        </div>

        <div id="gameOverOverlay" class="overlay hidden">
            <h2 style="color: var(--danger-color); margin-bottom: 5px;">GAME OVER</h2>
            <p id="finalScoreText" style="margin-bottom: 20px;">Score: 0</p>
            <button class="btn" onclick="startGame()">Play Again</button>
        </div>
    </div>

    <div class="controls-hint">
        <span><span class="key">ARROWS</span> or <span class="key">WASD</span> to Move</span>
        <span><span class="key">P</span> to Pause</span>
    </div>

    <div class="mobile-controls">
        <div></div>
        <div class="m-btn" onmousedown="handleMobileInput('UP')" ontouchstart="handleMobileInput('UP')">↑</div>
        <div></div>
        <div class="m-btn" onmousedown="handleMobileInput('LEFT')" ontouchstart="handleMobileInput('LEFT')">←</div>
        <div class="m-btn" onmousedown="handleMobileInput('DOWN')" ontouchstart="handleMobileInput('DOWN')">↓</div>
        <div class="m-btn" onmousedown="handleMobileInput('RIGHT')" ontouchstart="handleMobileInput('RIGHT')">→</div>
    </div>

    <footer>
        <a href="https://www.linkedin.com/in/md-nazmul-hasan-120346328/" target="_blank">
            <svg class="linkedin-icon" viewBox="0 0 24 24">
                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
            MD NAZMUL HASAN
        </a>
    </footer>
</div>

<script>
    const canvas = document.getElementById("game");
    const ctx = canvas.getContext("2d");
    const scoreElement = document.getElementById("score");
    const highScoreElement = document.getElementById("highScore");
    const levelElement = document.getElementById("level");
    const startOverlay = document.getElementById("startOverlay");
    const gameOverOverlay = document.getElementById("gameOverOverlay");
    const finalScoreText = document.getElementById("finalScoreText");

    // Game Constants
    const box = 20;
    const canvasSize = 400;
    const gridCount = canvasSize / box;

    // Game State
    let snake = [];
    let food = {};
    let direction = "RIGHT";
    let nextDirection = "RIGHT";
    let score = 0;
    let highScore = localStorage.getItem("snakeHighScore") || 0;
    let level = 1;
    let gameInterval = null;
    let isPaused = false;
    let gameRunning = false;
    let baseSpeed = 120;

    highScoreElement.innerText = highScore;

    // Initialize Game
    function initGame() {
        snake = [{x: 10 * box, y: 10 * box}, {x: 9 * box, y: 10 * box}, {x: 8 * box, y: 10 * box}];
        direction = "RIGHT";
        nextDirection = "RIGHT";
        score = 0;
        level = 1;
        scoreElement.innerText = score;
        levelElement.innerText = level;
        createFood();
        draw();
    }

    function createFood() {
        food = {
            x: Math.floor(Math.random() * gridCount) * box,
            y: Math.floor(Math.random() * gridCount) * box
        };
        // Check if food spawned on snake body
        for (let part of snake) {
            if (part.x === food.x && part.y === food.y) {
                createFood();
                break;
            }
        }
    }

    function startGame() {
        if (gameInterval) clearInterval(gameInterval);
        initGame();
        startOverlay.classList.add("hidden");
        gameOverOverlay.classList.add("hidden");
        gameRunning = true;
        isPaused = false;
        runGameLoop();
    }

    function runGameLoop() {
        const speed = Math.max(50, baseSpeed - (level - 1) * 10);
        gameInterval = setInterval(draw, speed);
    }

    function togglePause() {
        if (!gameRunning) return;
        isPaused = !isPaused;
        if (isPaused) {
            clearInterval(gameInterval);
            ctx.fillStyle = "rgba(0,0,0,0.5)";
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = "white";
            ctx.font = "30px Arial";
            ctx.textAlign = "center";
            ctx.fillText("PAUSED", canvasSize/2, canvasSize/2);
        } else {
            runGameLoop();
        }
    }

    function gameOver() {
        gameRunning = false;
        clearInterval(gameInterval);
        if (score > highScore) {
            highScore = score;
            localStorage.setItem("snakeHighScore", highScore);
            highScoreElement.innerText = highScore;
        }
        finalScoreText.innerText = "Final Score: " + score;
        gameOverOverlay.classList.remove("hidden");
    }

    // Input Handling
    document.addEventListener("keydown", (e) => {
        const key = e.key;
        if (key === "ArrowLeft" || key === "a" || key === "A") {
            if (direction !== "RIGHT") nextDirection = "LEFT";
        } else if (key === "ArrowUp" || key === "w" || key === "W") {
            if (direction !== "DOWN") nextDirection = "UP";
        } else if (key === "ArrowRight" || key === "d" || key === "D") {
            if (direction !== "LEFT") nextDirection = "RIGHT";
        } else if (key === "ArrowDown" || key === "s" || key === "S") {
            if (direction !== "UP") nextDirection = "DOWN";
        } else if (key === "p" || key === "P") {
            togglePause();
        }
    });

    function handleMobileInput(dir) {
        if (dir === "LEFT" && direction !== "RIGHT") nextDirection = "LEFT";
        if (dir === "UP" && direction !== "DOWN") nextDirection = "UP";
        if (dir === "RIGHT" && direction !== "LEFT") nextDirection = "RIGHT";
        if (dir === "DOWN" && direction !== "UP") nextDirection = "DOWN";
    }

    // Visual Effects
    function createParticles(x, y, color) {
        const gameArea = document.getElementById("gameArea");
        for (let i = 0; i < 8; i++) {
            const p = document.createElement("div");
            p.className = "particle";
            p.style.left = (x + box/2) + "px";
            p.style.top = (y + box/2) + "px";
            p.style.width = "6px";
            p.style.height = "6px";
            p.style.backgroundColor = color;
            
            const angle = Math.random() * Math.PI * 2;
            const velocity = 2 + Math.random() * 3;
            const vx = Math.cos(angle) * velocity;
            const vy = Math.sin(angle) * velocity;
            
            gameArea.appendChild(p);
            
            let pos = {x: 0, y: 0};
            let opacity = 1;
            
            const anim = setInterval(() => {
                pos.x += vx;
                pos.y += vy;
                opacity -= 0.05;
                p.style.transform = `translate(${pos.x}px, ${pos.y}px)`;
                p.style.opacity = opacity;
                
                if (opacity <= 0) {
                    clearInterval(anim);
                    p.remove();
                }
            }, 20);
        }
    }

    function draw() {
        if (isPaused) return;

        // Clear Canvas
        ctx.fillStyle = "#020617";
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        // Draw Grid (Subtle)
        ctx.strokeStyle = "rgba(255, 255, 255, 0.03)";
        for(let i=0; i<canvasSize; i+=box) {
            ctx.beginPath(); ctx.moveTo(i, 0); ctx.lineTo(i, canvasSize); ctx.stroke();
            ctx.beginPath(); ctx.moveTo(0, i); ctx.lineTo(canvasSize, i); ctx.stroke();
        }

        direction = nextDirection;

        // Snake Head Logic
        let headX = snake[0].x;
        let headY = snake[0].y;

        if (direction === "LEFT") headX -= box;
        if (direction === "UP") headY -= box;
        if (direction === "RIGHT") headX += box;
        if (direction === "DOWN") headY += box;

        // Check Collision
        if (
            headX < 0 || headY < 0 || 
            headX >= canvasSize || headY >= canvasSize || 
            snake.some((part, index) => index !== 0 && part.x === headX && part.y === headY)
        ) {
            gameOver();
            return;
        }

        const newHead = {x: headX, y: headY};

        // Check Food
        if (headX === food.x && headY === food.y) {
            score += 10;
            scoreElement.innerText = score;
            createParticles(food.x, food.y, "#ef4444");
            createFood();
            
            // Level up every 50 points
            let newLevel = Math.floor(score / 50) + 1;
            if (newLevel > level) {
                level = newLevel;
                levelElement.innerText = level;
                clearInterval(gameInterval);
                runGameLoop();
                // Level up flash
                canvas.style.borderColor = "#22c55e";
                setTimeout(() => canvas.style.borderColor = "#38bdf8", 500);
            }
        } else {
            snake.pop();
        }

        snake.unshift(newHead);

        // Draw Snake
        snake.forEach((part, i) => {
            const isHead = i === 0;
            ctx.fillStyle = isHead ? "#22c55e" : "#4ade80";
            
            // Rounded rectangle for snake body
            const r = 4;
            ctx.beginPath();
            ctx.roundRect(part.x + 1, part.y + 1, box - 2, box - 2, r);
            ctx.fill();

            // Eyes for head
            if (isHead) {
                ctx.fillStyle = "white";
                let eyeSize = 3;
                if (direction === "RIGHT" || direction === "LEFT") {
                    ctx.fillRect(part.x + 12, part.y + 4, eyeSize, eyeSize);
                    ctx.fillRect(part.x + 12, part.y + 12, eyeSize, eyeSize);
                } else {
                    ctx.fillRect(part.x + 4, part.y + 4, eyeSize, eyeSize);
                    ctx.fillRect(part.x + 12, part.y + 4, eyeSize, eyeSize);
                }
            }
        });

        // Draw Food (Glow effect)
        ctx.shadowBlur = 15;
        ctx.shadowColor = "#ef4444";
        ctx.fillStyle = "#ef4444";
        ctx.beginPath();
        ctx.arc(food.x + box/2, food.y + box/2, box/2 - 2, 0, Math.PI * 2);
        ctx.fill();
        ctx.shadowBlur = 0;
    }

    // Initial draw to show the start screen
    ctx.fillStyle = "#020617";
    ctx.fillRect(0, 0, canvas.width, canvas.height);
</script>

</body>
</html>
