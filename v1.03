<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Snake Game v4.0 - Ultimate Edition</title>
    <style>
        :root {
            --bg-color: #020617;
            --canvas-bg: #000000;
            --primary-color: #38bdf8;
            --secondary-color: #22c55e;
            --danger-color: #ef4444;
            --text-color: #f8fafc;
            --panel-bg: rgba(15, 23, 42, 0.9);
            --gold: #fbbf24;
            --purple: #a855f7;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            overflow: hidden;
            transition: transform 0.1s ease-out; /* For screen shake */
        }

        .container {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
            padding: 20px;
            max-width: 600px;
            width: 100%;
        }

        header { width: 100%; display: flex; justify-content: space-between; align-items: center; }
        h1 { font-size: 1.8rem; background: linear-gradient(45deg, var(--primary-color), var(--purple)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

        .stats-panel {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            width: 100%;
            background: var(--panel-bg);
            padding: 10px;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.1);
            text-align: center;
        }

        .stat-label { font-size: 0.6rem; color: #94a3b8; text-transform: uppercase; }
        .stat-value { font-size: 1.1rem; font-weight: bold; color: var(--primary-color); }

        .game-wrapper { position: relative; line-height: 0; }
        canvas {
            background: var(--canvas-bg);
            border: 3px solid var(--primary-color);
            border-radius: 8px;
            box-shadow: 0 0 30px rgba(56, 189, 248, 0.2);
            max-width: 100%;
        }

        .overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            background: rgba(0,0,0,0.85); z-index: 100; border-radius: 8px;
            text-align: center; padding: 20px;
        }

        .btn {
            background: var(--primary-color);
            color: #000; border: none; padding: 12px 24px;
            font-weight: bold; border-radius: 6px; cursor: pointer;
            margin: 10px; text-transform: uppercase; transition: transform 0.2s;
        }
        .btn:hover { transform: scale(1.05); filter: brightness(1.1); }

        .shop-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            margin: 15px 0;
        }
        .skin-item {
            padding: 8px; border: 1px solid #334155; border-radius: 6px; cursor: pointer;
            font-size: 0.7rem; transition: all 0.2s;
        }
        .skin-item.selected { border-color: var(--primary-color); background: rgba(56, 189, 248, 0.1); }
        .skin-preview { width: 100%; height: 20px; margin-bottom: 5px; border-radius: 2px; }

        .powerup-indicator {
            position: absolute; top: 10px; right: 10px;
            display: flex; flex-direction: column; gap: 5px;
        }
        .p-badge {
            padding: 4px 8px; border-radius: 4px; font-size: 0.7rem; font-weight: bold;
            animation: pulse 1s infinite alternate;
        }

        @keyframes pulse { from { opacity: 0.6; } to { opacity: 1; } }

        .hidden { display: none !important; }
        footer { margin-top: 15px; font-size: 0.8rem; }
        footer a { color: var(--primary-color); text-decoration: none; font-weight: bold; }

        /* Mobile Controls */
        .mobile-controls { display: none; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-top: 10px; }
        .m-btn { width: 50px; height: 50px; background: var(--panel-bg); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; cursor: pointer; border: 1px solid #334155; }

        @media (max-width: 500px) {
            .mobile-controls { display: grid; }
            .stats-panel { grid-template-columns: repeat(2, 1fr); gap: 5px; }
        }
    </style>
</head>
<body>

<div class="container">
    <header>
        <h1>ULTIMATE SNAKE</h1>
        <div id="soundToggle" style="cursor:pointer; font-size: 1.2rem;" onclick="toggleSound()">🔊</div>
    </header>

    <div class="stats-panel">
        <div class="stat">
            <div class="stat-label">Score</div>
            <div id="score" class="stat-value">0</div>
        </div>
        <div class="stat">
            <div class="stat-label">Coins</div>
            <div id="coins" class="stat-value">0</div>
        </div>
        <div class="stat">
            <div class="stat-label">High Score</div>
            <div id="highScore" class="stat-value">0</div>
        </div>
        <div class="stat">
            <div class="stat-label">Level</div>
            <div id="level" class="stat-value">1</div>
        </div>
    </div>

    <div class="game-wrapper">
        <canvas id="game" width="400" height="400"></canvas>
        <div id="powerupIndicator" class="powerup-indicator"></div>
        
        <div id="startOverlay" class="overlay">
            <h2 style="color: var(--primary-color);">VERSION 4.0</h2>
            <p style="font-size: 0.8rem; margin: 10px 0; color: #94a3b8;">COLLECT COINS TO UNLOCK SKINS</p>
            
            <div class="shop-grid">
                <div class="skin-item selected" onclick="selectSkin('neon', 0)">
                    <div class="skin-preview" style="background: #22c55e;"></div>
                    NEON
                </div>
                <div class="skin-item" id="skin-rainbow" onclick="selectSkin('rainbow', 50)">
                    <div class="skin-preview" style="background: linear-gradient(to right, red, orange, yellow, green, blue, violet);"></div>
                    RAINBOW (50)
                </div>
                <div class="skin-item" id="skin-gold" onclick="selectSkin('gold', 150)">
                    <div class="skin-preview" style="background: #fbbf24;"></div>
                    GOLD (150)
                </div>
            </div>

            <button class="btn" onclick="startGame()">START MISSION</button>
        </div>

        <div id="gameOverOverlay" class="overlay hidden">
            <h2 style="color: var(--danger-color);">MISSION FAILED</h2>
            <p id="finalScoreText" style="margin: 10px 0;">SCORE: 0</p>
            <button class="btn" onclick="startGame()">REDEPLOY</button>
            <button class="btn" style="background: #334155; color: white;" onclick="showMenu()">MENU</button>
        </div>
    </div>

    <div class="mobile-controls">
        <div></div><div class="m-btn" onmousedown="handleInput('UP')">↑</div><div></div>
        <div class="m-btn" onmousedown="handleInput('LEFT')">←</div>
        <div class="m-btn" onmousedown="handleInput('DOWN')">↓</div>
        <div class="m-btn" onmousedown="handleInput('RIGHT')">→</div>
    </div>

    <footer>
        <a href="https://www.linkedin.com/in/md-nazmul-hasan-120346328/" target="_blank">MD NAZMUL HASAN</a>
    </footer>
</div>

<script>
    // --- Audio System ---
    const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    let isMuted = false;
    function playSound(f, t, d, v=0.1) {
        if(isMuted) return;
        const o = audioCtx.createOscillator(), g = audioCtx.createGain();
        o.type = t; o.frequency.setValueAtTime(f, audioCtx.currentTime);
        g.gain.setValueAtTime(v, audioCtx.currentTime);
        g.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + d);
        o.connect(g); g.connect(audioCtx.destination);
        o.start(); o.stop(audioCtx.currentTime + d);
    }
    const sfx = {
        eat: () => playSound(800, 'sine', 0.1),
        coin: () => { playSound(1200, 'sine', 0.1); setTimeout(() => playSound(1500, 'sine', 0.1), 50); },
        power: () => playSound(400, 'square', 0.3),
        hit: () => { screenShake(); playSound(100, 'sawtooth', 0.4); },
        move: () => playSound(200, 'sine', 0.05, 0.02)
    };
    function toggleSound() { isMuted = !isMuted; document.getElementById('soundToggle').innerText = isMuted ? '🔇' : '🔊'; }

    // --- Game Engine ---
    const canvas = document.getElementById("game"), ctx = canvas.getContext("2d");
    const box = 20, grid = 20;
    let snake, food, coins_obj, powerup, obstacles = [], direction, nextDir, score, totalCoins, level, gameInterval, gameRunning, activePowerup = null;
    let currentSkin = 'neon';
    let ownedSkins = JSON.parse(localStorage.getItem('snakeSkins')) || ['neon'];
    let highScore = localStorage.getItem('snakeHighV4') || 0;
    totalCoins = parseInt(localStorage.getItem('snakeCoins')) || 0;

    function updateUI() {
        document.getElementById('score').innerText = score;
        document.getElementById('coins').innerText = totalCoins;
        document.getElementById('highScore').innerText = highScore;
        document.getElementById('level').innerText = level;
        ownedSkins.forEach(s => {
            const el = document.getElementById('skin-' + s);
            if(el) el.innerText = s.toUpperCase() + " (OWNED)";
        });
    }

    function selectSkin(skin, price) {
        if(ownedSkins.includes(skin)) {
            currentSkin = skin;
            document.querySelectorAll('.skin-item').forEach(i => i.classList.remove('selected'));
            event.currentTarget.classList.add('selected');
            playSound(600, 'sine', 0.1);
        } else if(totalCoins >= price) {
            totalCoins -= price;
            ownedSkins.push(skin);
            localStorage.setItem('snakeCoins', totalCoins);
            localStorage.setItem('snakeSkins', JSON.stringify(ownedSkins));
            selectSkin(skin, 0);
            updateUI();
        } else {
            playSound(150, 'sawtooth', 0.2);
        }
    }

    function screenShake() {
        document.body.style.transform = `translate(${Math.random()*10-5}px, ${Math.random()*10-5}px)`;
        setTimeout(() => document.body.style.transform = 'translate(0,0)', 100);
    }

    function createItem(type) {
        let pos = { x: Math.floor(Math.random()*grid)*box, y: Math.floor(Math.random()*grid)*box };
        if(snake.some(p => p.x === pos.x && p.y === pos.y) || obstacles.some(o => o.x === pos.x && o.y === pos.y)) return createItem(type);
        return pos;
    }

    function spawnObstacle() {
        if(level > 1) obstacles.push(createItem('obstacle'));
    }

    function initGame() {
        snake = [{x: 10*box, y: 10*box}, {x: 9*box, y: 10*box}];
        direction = nextDir = "RIGHT";
        score = 0; level = 1; obstacles = []; activePowerup = null;
        food = createItem('food');
        coins_obj = Math.random() > 0.7 ? createItem('coin') : null;
        powerup = Math.random() > 0.9 ? { ...createItem('power'), type: 'GHOST' } : null;
        updateUI();
    }

    function startGame() {
        if(audioCtx.state === 'suspended') audioCtx.resume();
        initGame();
        document.getElementById('startOverlay').classList.add('hidden');
        document.getElementById('gameOverOverlay').classList.add('hidden');
        gameRunning = true;
        runLoop();
    }

    function showMenu() {
        document.getElementById('gameOverOverlay').classList.add('hidden');
        document.getElementById('startOverlay').classList.remove('hidden');
        updateUI();
    }

    function runLoop() {
        if(gameInterval) clearInterval(gameInterval);
        let speed = Math.max(50, 120 - (level*10));
        if(activePowerup === 'SLOW') speed *= 1.5;
        gameInterval = setInterval(draw, speed);
    }

    function handleInput(d) {
        if(d === 'UP' && direction !== 'DOWN') nextDir = 'UP';
        if(d === 'DOWN' && direction !== 'UP') nextDir = 'DOWN';
        if(d === 'LEFT' && direction !== 'RIGHT') nextDir = 'LEFT';
        if(d === 'RIGHT' && direction !== 'LEFT') nextDir = 'RIGHT';
    }

    window.addEventListener('keydown', e => {
        const k = e.key.toUpperCase();
        if((k === 'ARROWUP' || k === 'W')) handleInput('UP');
        if((k === 'ARROWDOWN' || k === 'S')) handleInput('DOWN');
        if((k === 'ARROWLEFT' || k === 'A')) handleInput('LEFT');
        if((k === 'ARROWRIGHT' || k === 'D')) handleInput('RIGHT');
    });

    function draw() {
        direction = nextDir;
        let head = { ...snake[0] };
        if(direction === 'UP') head.y -= box;
        if(direction === 'DOWN') head.y += box;
        if(direction === 'LEFT') head.x -= box;
        if(direction === 'RIGHT') head.x += box;

        // Collision Logic
        let hitWall = head.x < 0 || head.y < 0 || head.x >= 400 || head.y >= 400;
        let hitSelf = snake.some(p => p.x === head.x && p.y === head.y);
        let hitObstacle = obstacles.some(o => o.x === head.x && o.y === head.y);

        if((hitWall || hitSelf || hitObstacle) && activePowerup !== 'GHOST') {
            sfx.hit();
            gameRunning = false;
            clearInterval(gameInterval);
            if(score > highScore) { highScore = score; localStorage.setItem('snakeHighV4', highScore); }
            localStorage.setItem('snakeCoins', totalCoins);
            document.getElementById('finalScoreText').innerText = "SCORE: " + score + " | COINS: " + totalCoins;
            document.getElementById('gameOverOverlay').classList.remove('hidden');
            return;
        }

        // Wrap around if Ghost
        if(activePowerup === 'GHOST') {
            if(head.x < 0) head.x = 380; if(head.x >= 400) head.x = 0;
            if(head.y < 0) head.y = 380; if(head.y >= 400) head.y = 0;
        }

        snake.unshift(head);

        // Food & Items
        if(head.x === food.x && head.y === food.y) {
            score += 10; sfx.eat(); food = createItem('food');
            if(score % 50 === 0) { level++; spawnObstacle(); runLoop(); }
            if(Math.random() > 0.8 && !coins_obj) coins_obj = createItem('coin');
            if(Math.random() > 0.9 && !powerup) powerup = { ...createItem('power'), type: Math.random() > 0.5 ? 'GHOST' : 'SLOW' };
        } else if(coins_obj && head.x === coins_obj.x && head.y === coins_obj.y) {
            totalCoins += 5; sfx.coin(); coins_obj = null;
        } else if(powerup && head.x === powerup.x && head.y === powerup.y) {
            activePowerup = powerup.type; sfx.power();
            const badge = document.createElement('div');
            badge.className = 'p-badge';
            badge.style.background = activePowerup === 'GHOST' ? '#a855f7' : '#38bdf8';
            badge.innerText = activePowerup;
            document.getElementById('powerupIndicator').appendChild(badge);
            powerup = null;
            runLoop();
            setTimeout(() => { activePowerup = null; badge.remove(); runLoop(); }, 8000);
            snake.pop();
        } else {
            snake.pop();
        }

        // Render
        ctx.fillStyle = '#000'; ctx.fillRect(0,0,400,400);
        
        // Draw Obstacles
        ctx.fillStyle = '#334155';
        obstacles.forEach(o => ctx.fillRect(o.x+2, o.y+2, box-4, box-4));

        // Draw Items
        ctx.fillStyle = '#ef4444'; ctx.beginPath(); ctx.arc(food.x+10, food.y+10, 8, 0, Math.PI*2); ctx.fill();
        if(coins_obj) { ctx.fillStyle = '#fbbf24'; ctx.beginPath(); ctx.arc(coins_obj.x+10, coins_obj.y+10, 6, 0, Math.PI*2); ctx.fill(); }
        if(powerup) { ctx.fillStyle = powerup.type === 'GHOST' ? '#a855f7' : '#38bdf8'; ctx.fillRect(powerup.x+4, powerup.y+4, 12, 12); }

        // Draw Snake
        snake.forEach((p, i) => {
            if(currentSkin === 'neon') ctx.fillStyle = i === 0 ? '#38bdf8' : '#22c55e';
            else if(currentSkin === 'rainbow') ctx.fillStyle = `hsl(${(i * 20 + Date.now()/10) % 360}, 70%, 50%)`;
            else if(currentSkin === 'gold') ctx.fillStyle = '#fbbf24';
            
            if(activePowerup === 'GHOST') ctx.globalAlpha = 0.5;
            ctx.fillRect(p.x+1, p.y+1, box-2, box-2);
            ctx.globalAlpha = 1.0;
        });
        updateUI();
    }
    updateUI();
</script>
</body>
</html>
